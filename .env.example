# Copy to ".env" and fill in values. For local dev, `shopify app dev` often injects SHOPIFY_* from the linked app.

# --- PostgreSQL (required). Local: Neon dev branch, Supabase, or Docker. ---
# Pooled URL is fine for DATABASE_URL. DIRECT_URL must be a non-pooling URL for `prisma migrate` (on Vercel, use POSTGRES_URL_NON_POOLING); if you only have one URL, set both to the same non-pooled string.
DATABASE_URL=
DIRECT_URL=

# --- Shopify (Partner Dashboard → App → Client credentials) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Public HTTPS URL of this app (no trailing slash). MUST match shopify.app.toml [auth] / Partners "App URL".
# Do NOT use https://example.com — IANA reserves it and the embedded app will show a "documentation examples" warning page.
SHOPIFY_APP_URL=

# Optional: override OAuth scopes (comma-separated). Base scopes are in shopify.app.toml; merchants can grant write_draft_orders from the embedded app.
# SCOPES=write_products,write_app_proxy,read_orders,write_draft_orders

# Optional: custom shop domain for auth (e.g. storefront on a vanity domain).
# SHOP_CUSTOM_DOMAIN=store.example.com

# --- Dev server (optional) ---
# PORT=3000
# FRONTEND_PORT=8002

# --- Banner draft-order pricing (apps.proxy create-draft) ---
# USD charged per 3.5 sq ft billing increment (see app/routes/apps.proxy.$.ts).
BANNER_PRICE_PER_3_5_SQFT=28
